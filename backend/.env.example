APP_ENV=dev
APP_DOMAIN=http://localhost:8000
DB_USER=as_api_console
DB_PASSWORD=as_console_dev_pw
DB_HOST=localhost
DB_PORT=3306
DB_NAME=as_api_console
# Optional override:
# DATABASE_URL=mariadb+mariadbconnector://as_api_console:as_console_dev_pw@localhost:3306/as_api_console
TEST_DB_USER=as_api_console_test
TEST_DB_PASSWORD=as_console_dev_pw
TEST_DB_HOST=localhost
TEST_DB_PORT=3306
TEST_DB_NAME=as_api_console_test
# Optional override:
# TEST_DATABASE_URL=mariadb+mariadbconnector://as_api_console_test:as_console_dev_pw@localhost:3306/as_api_console_test
# 允許通過資格檢查的職稱代碼（逗號分隔，例如 RS01,RS02）
RESEARCH_LIST_ALLOWED_TITLE_CODES=
# Persnl SOAP runtime endpoint（可不填；若填寫將作為實際呼叫位址）
PERSNL_SOAP_URL=
# Persnl SOAP WSDL URL（可不填；填寫後可用 Zeep client）
PERSNL_SOAP_WSDL_URL=
# Persnl SOAP 帳號（單位主檔同步必填）
PERSNL_SOAP_USER=
# Persnl SOAP 密碼（單位主檔同步必填）
PERSNL_SOAP_PASSWORD=
# 呼叫 Persnl SOAP 的 timeout（秒）
PERSNL_SOAP_TIMEOUT_SECONDS=3.0
# 用於加密儲存 API Key 密文的主密鑰（正式環境請使用高強度隨機字串）
API_KEY_ENCRYPTION_SECRET=replace-with-strong-secret
# API Key 加密版本標記（供金鑰輪替/相容使用）
API_KEY_KEK_VERSION=v1
# 外部金鑰配發服務（provider）base URL；留空時改用本系統內建產生
PROVIDER_BASE_URL=
# 呼叫 provider 的授權金鑰/主金鑰
PROVIDER_MASTER_KEY=
# 呼叫 provider API 的 timeout（秒）
PROVIDER_TIMEOUT_SECONDS=3.0
# 金鑰配發模式：external|local（local 代表強制使用本系統內建產生，不呼叫 provider）
ISSUANCE_PROVIDER_MODE=external

# Session 簽章密鑰（正式環境請更換）
SESSION_SECRET_KEY=replace-with-strong-session-secret
# OAuth provider 名稱（寫入 auth_audit_logs）
OAUTH_PROVIDER=fisa
# OAuth/SSO 端點與 client 設定
OAUTH_AUTH_URI=
OAUTH_TOKEN_URI=
OAUTH_BASIC_URI=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
OAUTH_SCOPE=basic

# 是否啟用 Email 通知發送（true/false）
MAIL_ENABLED=false
# SMTP 伺服器位址（例如 smtp.office365.com）
MAIL_SERVER=
# SMTP 連接埠（常見 587 for STARTTLS、465 for SSL/TLS）
MAIL_PORT=587
# SMTP 帳號與密碼
MAIL_USERNAME=
MAIL_PASSWORD=
# 寄件者資訊（From）
MAIL_FROM=
MAIL_FROM_NAME=AS API Console
